<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/appBackground"
    tools:context=".ui.profile.RepositoryDetailActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/appSurfaceCard"
                app:cardCornerRadius="28dp"
                app:strokeColor="?attr/appStrokeColor"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/iv_repo_owner_avatar"
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            app:civ_border_color="?attr/colorPrimary"
                            app:civ_border_width="3dp"
                            tools:src="@tools:sample/avatars" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/repo_detail_owner_label"
                                android:textColor="?attr/appTextSecondary"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_repo_owner_login"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textColor="?attr/colorPrimary"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:text="@octocat" />

                            <TextView
                                android:id="@+id/tv_repo_detail_visibility"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:textColor="?attr/appTextSecondary"
                                android:textSize="13sp"
                                tools:text="Visibility: public" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_repo_detail_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:textColor="?attr/appTextPrimary"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        tools:text="GitHubUserRview" />

                    <TextView
                        android:id="@+id/tv_repo_detail_full_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="octocat/GitHubUserRview" />

                    <TextView
                        android:id="@+id/tv_repo_detail_state"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/repo_detail_state_live"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_repo_detail_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:textColor="?attr/appTextPrimary"
                        android:textSize="14sp"
                        tools:text="Repository description." />

                    <TextView
                        android:id="@+id/tv_repo_detail_overview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:textColor="?attr/appTextSecondary"
                        android:textSize="14sp"
                        tools:text="Language: Kotlin\nDefault branch: main\nLicense: MIT\nSize: 1024 KB" />

                    <TextView
                        android:id="@+id/tv_repo_detail_stats"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:textColor="?attr/appTextPrimary"
                        android:textSize="14sp"
                        tools:text="12 stars | 3 forks | 7 watchers | 1 issues" />

                    <TextView
                        android:id="@+id/tv_repo_detail_links"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:textColor="?attr/appTextSecondary"
                        android:textSize="14sp"
                        tools:text="GitHub: https://github.com/...\nHomepage: https://example.com" />

                    <TextView
                        android:id="@+id/tv_repo_detail_updated"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:textColor="?attr/appTextSecondary"
                        android:textSize="13sp"
                        tools:text="Updated 10 Mar 2026, 10:15" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="@string/repo_detail_branches_title"
                        android:textColor="?attr/appTextPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_repo_branches"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:chipSpacingHorizontal="8dp"
                        app:chipSpacingVertical="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="@string/repo_detail_contributors_title"
                        android:textColor="?attr/appTextPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_repo_contributors"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:chipSpacingHorizontal="8dp"
                        app:chipSpacingVertical="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="@string/repo_detail_issues_title"
                        android:textColor="?attr/appTextPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_repo_issues"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="?attr/appTextSecondary"
                        android:textSize="14sp"
                        tools:text="Open issue snapshot appears here." />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="@string/repo_detail_readme_title"
                        android:textColor="?attr/appTextPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_repo_readme"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="?attr/appTextSecondary"
                        android:textSize="14sp"
                        tools:text="# README\nA short project overview appears here." />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="@string/repo_detail_commits_title"
                        android:textColor="?attr/appTextPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_repo_commits"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="?attr/appTextSecondary"
                        android:textSize="14sp"
                        tools:text="• Initial commit&#10;Monalisa · 10 Mar 2026" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_repo_open_github"
                            style="@style/Widget.MaterialComponents.Button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/repo_detail_open_github"
                            android:textColor="?attr/colorOnPrimary"
                            app:backgroundTint="?attr/colorPrimary"
                            app:cornerRadius="18dp"
                            app:icon="@drawable/ic_icongithub"
                            app:iconTint="?attr/colorOnPrimary" />

                        <Space
                            android:layout_width="10dp"
                            android:layout_height="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_repo_open_homepage"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/repo_detail_open_homepage"
                            app:cornerRadius="18dp"
                            app:icon="@drawable/ic_baseline_home"
                            app:iconTint="?attr/colorPrimary"
                            app:strokeColor="?attr/colorSecondaryVariant" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_repo_open_owner_profile"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/repo_detail_open_owner_profile_default"
                        app:cornerRadius="18dp"
                        app:icon="@drawable/ic_baseline_contact_mail_24"
                        app:iconTint="?attr/colorPrimary"
                        app:strokeColor="?attr/colorSecondaryVariant" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_repo_refresh"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/settings_sync_refresh"
                        app:cornerRadius="18dp"
                        app:icon="@drawable/ic_refresh"
                        app:iconTint="?attr/colorPrimary"
                        app:strokeColor="?attr/colorSecondaryVariant" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/repo_detail_loading"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="center"
        android:visibility="gone"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:lottie_rawRes="@raw/meditatingmonkey" />

</FrameLayout>

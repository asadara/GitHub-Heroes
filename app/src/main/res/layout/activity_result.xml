<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/appBackground"
    tools:context=".ui.detail.ResultActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="96dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/appSurfaceCard"
                app:cardCornerRadius="28dp"
                app:cardElevation="4dp"
                app:strokeColor="?attr/appStrokeColor"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/iv_detail_photo"
                            android:layout_width="104dp"
                            android:layout_height="104dp"
                            card_view:civ_border_color="?attr/colorPrimary"
                            card_view:civ_border_width="4dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            tools:ignore="ContentDescription,ImageContrastCheck"
                            tools:src="@tools:sample/avatars" />

                        <androidx.appcompat.widget.AppCompatImageButton
                            android:id="@+id/toggleFav"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@android:color/transparent"
                            android:padding="8dp"
                            android:scaleType="centerInside"
                            android:focusable="false"
                            android:focusableInTouchMode="false"
                            android:tint="@null"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            tools:ignore="TouchTargetSizeCheck" />

                        <TextView
                            android:id="@+id/tv_profile_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:background="@drawable/bg_info_chip"
                            android:paddingStart="12dp"
                            android:paddingTop="6dp"
                            android:paddingEnd="12dp"
                            android:paddingBottom="6dp"
                            android:textColor="?attr/appChipTextColor"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toEndOf="@id/iv_detail_photo"
                            app:layout_constraintTop_toTopOf="@id/iv_detail_photo"
                            tools:text="High reach profile" />

                        <TextView
                            android:id="@+id/tv_detail_name"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginTop="12dp"
                            android:layout_marginEnd="16dp"
                            android:textColor="?attr/appTextPrimary"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toStartOf="@id/toggleFav"
                            app:layout_constraintStart_toEndOf="@id/iv_detail_photo"
                            app:layout_constraintTop_toBottomOf="@id/tv_profile_badge"
                            tools:text="Jake Wharton" />

                        <TextView
                            android:id="@+id/tv_detail_id"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginTop="4dp"
                            android:layout_marginEnd="16dp"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toStartOf="@id/toggleFav"
                            app:layout_constraintStart_toEndOf="@id/iv_detail_photo"
                            app:layout_constraintTop_toBottomOf="@id/tv_detail_name"
                            tools:text="@jakewharton" />

                        <TextView
                            android:id="@+id/tv_profile_type"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginTop="6dp"
                            android:layout_marginEnd="16dp"
                            android:textColor="?attr/appTextSecondary"
                            android:textSize="13sp"
                            app:layout_constraintEnd_toStartOf="@id/toggleFav"
                            app:layout_constraintStart_toEndOf="@id/iv_detail_photo"
                            app:layout_constraintTop_toBottomOf="@id/tv_detail_id"
                            tools:text="User | Joined January 2010" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_open_profile"
                            style="@style/Widget.MaterialComponents.Button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/detail_open_profile"
                            android:textColor="?attr/colorOnPrimary"
                            app:backgroundTint="?attr/colorPrimary"
                            app:cornerRadius="18dp"
                            app:icon="@drawable/ic_baseline_home"
                            app:iconTint="?attr/colorOnPrimary" />

                        <Space
                            android:layout_width="10dp"
                            android:layout_height="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_open_blog"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/detail_open_blog"
                            app:cornerRadius="18dp"
                            app:icon="@drawable/ic_baseline_contact_mail_24"
                            app:iconTint="?attr/colorPrimary"
                            app:strokeColor="?attr/colorSecondaryVariant" />

                        <Space
                            android:layout_width="10dp"
                            android:layout_height="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnShare"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/detail_share"
                            app:cornerRadius="18dp"
                            app:icon="@drawable/ic_baseline_share"
                            app:iconTint="?attr/colorPrimary"
                            app:strokeColor="?attr/colorSecondaryVariant" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:cardBackgroundColor="?attr/appSurfaceTint"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <TextView
                                    android:id="@+id/tv_stat_followers_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="?attr/appTextPrimary"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    tools:text="56,995" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/detail_followers_label"
                                    android:textColor="?attr/appTextSecondary"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <Space
                            android:layout_width="10dp"
                            android:layout_height="1dp" />

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:cardBackgroundColor="?attr/appSurfaceTint"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <TextView
                                    android:id="@+id/tv_stat_following_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="?attr/appTextPrimary"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    tools:text="12" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/detail_following_label"
                                    android:textColor="?attr/appTextSecondary"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <Space
                            android:layout_width="10dp"
                            android:layout_height="1dp" />

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:cardBackgroundColor="?attr/appSurfaceTint"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <TextView
                                    android:id="@+id/tv_stat_repos_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="?attr/appTextPrimary"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    tools:text="102" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/detail_repositories_label"
                                    android:textColor="?attr/appTextSecondary"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <Space
                            android:layout_width="10dp"
                            android:layout_height="1dp" />

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:cardBackgroundColor="?attr/appSurfaceTint"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <TextView
                                    android:id="@+id/tv_stat_gists_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="?attr/appTextPrimary"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    tools:text="14" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/detail_gists_label"
                                    android:textColor="?attr/appTextSecondary"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="?attr/appSurfaceCard"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeColor="?attr/appStrokeColor"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/detail_overview_title"
                        android:textColor="?attr/appTextPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_detail_profile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="?attr/appTextPrimary"
                        android:textSize="14sp"
                        tools:text="Company: Google\nLocation: Pittsburgh, PA, USA\nPublic repos: 102\nPublic gists: 24" />

                    <TextView
                        android:id="@+id/tv_profile_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:textColor="?attr/appTextSecondary"
                        android:textSize="14sp"
                        tools:text="Bio or generated summary goes here." />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="?attr/appSurfaceCard"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeColor="?attr/appStrokeColor"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/detail_insight_section_title"
                        android:textColor="?attr/appTextPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_insight_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        tools:text="High reach profile" />

                    <TextView
                        android:id="@+id/tv_insight_body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="?attr/appTextSecondary"
                        android:textSize="14sp"
                        tools:text="Strong follower ratio and a healthy public footprint." />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="?attr/appSurfaceCard"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeColor="?attr/appStrokeColor"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/detail_links_title"
                        android:textColor="?attr/appTextPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_web"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="Profile: https://github.com/jakewharton" />

                    <TextView
                        android:id="@+id/tv_blog"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="?attr/appTextSecondary"
                        android:textSize="14sp"
                        tools:text="Blog: https://jakewharton.com" />

                    <TextView
                        android:id="@+id/tv_organizations_url"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="?attr/appTextSecondary"
                        android:textSize="14sp"
                        tools:text="Organizations API: https://api.github.com/users/jakewharton/orgs" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="?attr/colorPrimary"
                app:tabIndicatorColor="?attr/colorSecondary"
                app:tabSelectedTextColor="?attr/colorSecondary"
                app:tabTextColor="?attr/colorOnPrimary"
                tools:ignore="SpeakableTextPresentCheck" />

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/view_pager"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:layout_marginTop="8dp"
                android:background="?attr/appSurfaceCard"
                tools:ignore="NestedScrolling" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottie"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="center"
        android:visibility="gone"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:lottie_rawRes="@raw/meditatingmonkey"
        tools:ignore="ImageContrastCheck" />

    <include
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        layout="@layout/include_bottom_nav" />

</FrameLayout>
